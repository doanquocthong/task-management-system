@model task_management_system.Models.ViewModels.Project.ProjectCreateViewModel

<div class="container py-4">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
                <h4 class="fw-bold text-dark mb-3">Cập nhật Dự án</h4>
                <hr class="opacity-25 mb-4">

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium small text-secondary">Tên dự án</label>
                        <input asp-for="Name" class="form-control rounded-2" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-medium small text-secondary">Mô tả dự án</label>
                        <textarea asp-for="Description" class="form-control rounded-2" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light btn-sm px-3 rounded-2 text-secondary border">Quay lại</a>
                        <button type="submit" class="btn btn-dark btn-sm px-4 rounded-2">Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}