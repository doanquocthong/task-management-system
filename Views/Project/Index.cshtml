@model IEnumerable<task_management_system.Models.ViewModels.Project.ProjectViewModel>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">Danh sách Dự án</h2>
            <p class="text-muted small m-0">Quản lý và theo dõi tiến độ các dự án hiện tại</p>
        </div>
        @if (User.IsInRole("Manager"))
        {
            <a asp-action="Create" class="btn btn-dark btn-sm px-3 py-2 rounded-2 fw-medium">
                <i class="bi bi-plus-lg me-1"></i> Tạo Dự án Mới
            </a>
        }
    </div>

    <div class="row g-3">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">Chưa có dự án nào được tạo.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-2 shadow-sm rounded-3 bg-white">
                        <div class="card-body p-4 d-flex flex-column">
                            <h5 class="fw-bold text-dark mb-1">@item.Name</h5>
                            <small class="text-muted mb-3 d-block">Người tạo: @item.CreatorName</small>

                            <p class="text-secondary small flex-grow-1 text-truncate-2">
                                @(string.IsNullOrEmpty(item.Description) ? "Không có mô tả cho dự án này." : item.Description)
                            </p>

                            <div class="border-top pt-3 mt-3 d-flex justify-content-between align-items-center">
                                <span class="badge bg-light text-dark border">
                                    <i class="bi bi-list-task me-1"></i> @item.TaskCount Công việc
                                </span>

                                <div class="d-flex gap-2">
                                    @if (User.IsInRole("Manager"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary px-2 py-1 rounded-2">
                                            Sửa
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa dự án này? Toàn bộ task con sẽ bị xóa theo!');" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1 rounded-2">Xóa</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>