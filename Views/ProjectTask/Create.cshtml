@model task_management_system.Models.ViewModels.ProjectTask.ProjectTaskCreateViewModel

<div class="container py-4">
    <div class="row">
        <div class="col-md-7 mx-auto">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
                <h4 class="fw-bold text-dark mb-1">Phân công Công việc mới</h4>
                <p class="text-muted small mb-3">Tạo công việc và chỉ định nhân viên thực hiện trực tiếp từ hệ thống.</p>
                <hr class="opacity-25 mb-4">

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ProjectId" class="form-label fw-medium small text-secondary">Thuộc Dự án</label>
                        <select asp-for="ProjectId" asp-items="Model.ProjectList" class="form-select rounded-2">
                            <option value="">-- Chọn dự án quản lý --</option>
                        </select>
                        <span asp-validation-for="ProjectId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-medium small text-secondary">Tiêu đề công việc</label>
                        <input asp-for="Title" class="form-control rounded-2" placeholder="Ví dụ: Thiết kế giao diện database..." />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-medium small text-secondary">Mô tả nội dung việc</label>
                        <textarea asp-for="Description" class="form-control rounded-2" rows="3" placeholder="Nhập yêu cầu chi tiết của task..."></textarea>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="AssigneeId" class="form-label fw-medium small text-secondary">Giao cho nhân viên</label>
                            <select asp-for="AssigneeId" asp-items="Model.UserList" class="form-select rounded-2">
                                <option value="">-- Chưa giao / Để trống --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DueDate" class="form-label fw-medium small text-secondary">Hạn chót (Due Date)</label>
                            <input asp-for="DueDate" class="form-control rounded-2" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light btn-sm px-3 rounded-2 text-secondary border">Hủy</a>
                        <button type="submit" class="btn btn-dark btn-sm px-4 rounded-2">Phân công việc</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}