@model IEnumerable<task_management_system.Models.ViewModels.ProjectTask.ProjectTaskViewModel>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">Bảng theo dõi Công việc</h2>
            <p class="text-muted small m-0">Danh sách toàn bộ các task đang chạy trong hệ thống</p>
        </div>
        @if (User.IsInRole("Manager"))
        {
            <a asp-action="Create" class="btn btn-dark btn-sm px-3 py-2 rounded-2 fw-medium">
                <i class="bi bi-plus-lg me-1"></i> Tạo Task & Giao Việc
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-3 bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tên Công việc</th>
                        <th>Dự án</th>
                        <th>Người được giao</th>
                        <th>Hạn chót</th>
                        <th>Trạng thái</th>
                        @if (User.IsInRole("Manager"))
                        {
                            <th class="text-end pe-4">Hành động</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Chưa có công việc nào được phân công.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold text-dark">@item.Title</div>
                                    <small class="text-muted">Giao bởi: @item.CreatorName</small>
                                </td>
                                <td><span class="badge bg-light text-dark border">@item.ProjectName</span></td>
                                <td><span class="text-dark fw-medium">@item.AssigneeName</span></td>
                                <td class="text-secondary small">@(item.DueDate.HasValue ? item.DueDate.Value.ToString("dd/MM/yyyy") : "Không có")</td>
                                <td>
                                    <span class="badge @(item.Status.ToString() == "Pending" ? "bg-warning text-dark" : item.Status.ToString() == "Success" ? "bg-success" : "bg-secondary")">
                                        @item.Status.ToString()
                                    </span>
                                </td>
                                @if (User.IsInRole("Manager"))
                                {
                                    <td class="text-end pe-4">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-link link-secondary p-0 me-2 text-decoration-none">Sửa</a>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa việc này?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-link link-danger p-0 text-decoration-none">Xóa</button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>