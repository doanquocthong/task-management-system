@model task_management_system.Models.ViewModels.Auth.RegisterViewModel

<div class="container d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="card shadow-sm p-4" style="width: 100%; max-width: 450px; border-radius: 10px;">

        <h2 class="text-center mb-4 text-dark fw-bold">Register</h2>

        <!-- Hiển thị thông báo lỗi tổng quan từ Server nếu đăng ký thất bại -->
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <form asp-action="Register" method="post">

            <!-- Ô nhập Full Name -->
            <div class="form-group mb-3">
                <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <!-- Ô nhập Email -->
            <div class="form-group mb-3">
                <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <!-- Ô nhập Password -->
            <div class="form-group mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Create a password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <!-- Ô nhập Confirm Password -->
            <div class="form-group mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <!-- Nút Register full chiều rộng -->
            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-dark btn-block py-2 fw-bold">
                    Register
                </button>
            </div>

            <!-- Dòng liên kết quay lại trang Login -->
            <div class="text-center mt-3">
                <p class="text-muted small mb-0">
                    Already have an account?
                    <a asp-controller="Auth" asp-action="Login" class="text-dark fw-semibold text-decoration-none">
                        Login here
                    </a>
                </p>
            </div>

        </form>
    </div>
</div>