<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - task-management-system</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/task-management-system.styles.css" asp-append-version="true" />
</head>
<body class="bg-light-subtle">

    <nav class="navbar navbar-expand-md navbar-light bg-white shadow-sm border-bottom py-3 mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold text-dark" asp-controller="Home" asp-action="Index" style="letter-spacing: -0.5px;">
                Task Management
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-md-0 ms-md-4 gap-2">
                    <li class="nav-item">
                        <a class="nav-link text-secondary fw-medium px-2 small" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    @if (User.Identity!.IsAuthenticated)
                    {
                        @if (User.IsInRole("Manager"))

                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-controller="Project" asp-action="Index">Dự án</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-controller="ProjectTask" asp-action="Index">Bảng công việc tổng quan</a>
                            </li>
                        }
                    }
                </ul>

                <div class="d-flex align-items-center">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <span class="text-secondary small me-3">
                            Hi, <span class="fw-semibold text-dark">@User.Identity.Name</span>
                        </span>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-link link-secondary text-decoration-none small p-0 border-0">
                                Logout
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-dark btn-sm px-3 rounded-2 me-2">Sign In</a>
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-light btn-sm px-3 border rounded-2 text-secondary">Sign Up</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </div>
</body>
<script src="~/js/handle-delete-btn.js"></script>
</html>